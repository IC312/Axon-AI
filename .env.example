# ─── Astra DB ────────────────────────────────────────────────────────────────
# Lấy từ: https://astra.datastax.com → tạo database → Generate Token
ASTRA_DB_APPLICATION_TOKEN=AstraCS:xxxx
ASTRA_DB_API_ENDPOINT=https://xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx-us-east1.apps.astra.datastax.com

# Tên namespace/keyspace trong Astra DB
ASTRA_DB_NAMESPACE=default_keyspace

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Chuỗi bí mật dùng để ký JWT — nên dài ≥ 32 ký tự, ngẫu nhiên
JWT_SECRET=change_this_to_a_long_random_string_at_least_32_chars

# ─── Groq AI — Chat chính (hỗ trợ failover tối đa 5 key) ────────────────────
# Lấy tại: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_primary_key_here
GROQ_API_KEY_2=gsk_your_second_key_here
GROQ_API_KEY_3=gsk_your_third_key_here
GROQ_API_KEY_4=
GROQ_API_KEY_5=

# ─── Groq AI — Kiểm duyệt nội dung (tách riêng để tránh quota chồng chéo) ──
GROQ_MOD_KEY_1=gsk_your_moderation_key_1_here
GROQ_MOD_KEY_2=gsk_your_moderation_key_2_here

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
